{
  "appId": "com.caja.grit",
  "productName": "CajaGrit",
  "directories": {
    "output": "dist"
  },
  "files": [
    "electron.js",
    "package.json",
    "index.js",
    "node_modules/**/*",
    "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
